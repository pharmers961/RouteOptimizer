rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/savedAddresses/{addressId} {
      function incoming() { return request.resource.data; }
      function existing() { return resource.data; }
      
      function isValidSavedAddress(data) {
        return data.keys().hasAll(['id', 'userId', 'address', 'displayName', 'lat', 'lon', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.id is string
        && data.id.size() <= 128
        && data.userId is string
        && data.userId == userId
        && data.address is string
        && data.address.size() > 0
        && data.address.size() <= 500
        && data.displayName is string
        && data.displayName.size() <= 500
        && data.lat is number
        && data.lon is number
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
      }
      
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(addressId)
                    && isValidSavedAddress(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(addressId)
                    && isValidSavedAddress(incoming())
                    && incoming().id == existing().id
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['address', 'displayName', 'lat', 'lon', 'updatedAt']);
                    
      allow delete: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(addressId);
    }
  }
}
