# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: required. Find in Supabase dashboard -> Project settings
# -> API. Looks like https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# VITE_SUPABASE_ANON_KEY: required. The anon/public key from the same page.
# Safe to expose to the browser; Row Level Security gates table access.
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# VITE_MAPBOX_TOKEN (recommended): Mapbox access token. Enables the Mapbox
# geocoder, which has real US address coverage with house-number interpolation
# and autocomplete-grade ranking. Free up to 100k searches/month. Create a
# token at https://account.mapbox.com/access-tokens/ (the default public token
# works). When unset, the app falls back to keyless Nominatim (OSM), which is
# weak on US residential addresses.
# VITE_MAPBOX_TOKEN="pk.xxxxx"

# VITE_MAPBOX_MONTHLY_BUDGET (optional): hard cap on Mapbox geocoding requests
# per browser per calendar month. Once reached, the app silently falls back to
# keyless Nominatim so you never spend past the free tier. Default 25000 (the
# free tier is 100000/month account-wide). The app also caches results to
# avoid repeat requests.
# VITE_MAPBOX_MONTHLY_BUDGET="25000"

# VITE_GEOCODER_BASE_URL (optional): only used for the Nominatim fallback.
# Override to a Nominatim-compatible mirror (LocationIQ, Geoapify, self-hosted).
# Ignored when VITE_MAPBOX_TOKEN is set.
# VITE_GEOCODER_BASE_URL=""

# VITE_GEOCODER_API_KEY (optional): API key for the Nominatim mirror above,
# sent as the `key` query parameter. Ignored when VITE_MAPBOX_TOKEN is set.
# VITE_GEOCODER_API_KEY=""

# VITE_GEMINI_MODEL (optional): override the model used for AI address assist.
# Defaults to gemini-2.5-flash.
# VITE_GEMINI_MODEL="gemini-2.5-flash"
